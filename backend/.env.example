# Copy this file to .env and fill in your real values.
# NEVER commit the real .env to GitHub.

# Server
PORT=5000
CLIENT_URL=http://localhost:5173

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=studybuddy

# JWT
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES=1d
JWT_EXPIRES_REMEMBER=30d

# Email (Nodemailer) - optional until Step 4
# For Gmail: create an "App Password" at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="StudyBuddy <youremail@gmail.com>"
